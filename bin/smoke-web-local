#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")/.."
export PYTHONPATH="$PWD/src${PYTHONPATH:+:$PYTHONPATH}"
export PYTHONDONTWRITEBYTECODE=1

if [ ! -x .venv/bin/python ]; then
  echo "Missing .venv. Run ./bin/onboard first."
  exit 1
fi

.venv/bin/python -m route74.smoke.web_runtime_smoke
